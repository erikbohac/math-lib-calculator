root = true

# Default settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
tab_width = 4
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Qt UI files
[*.ui]
indent_style = tab
tab_width = 4
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab
tab_width = 4
indent_size = 4

# CMake
[CMakeLists.txt]
indent_style = tab
tab_width = 4
indent_size = 4
